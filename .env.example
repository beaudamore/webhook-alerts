# Receiver runtime
APP_HOST=0.0.0.0
APP_PORT=8080

# Image used by compose.ghcr.yml. Override for your GHCR owner/repo.
WEBHOOK_ALERTS_IMAGE=ghcr.io/beaudamore/webhook-alerts:latest

# Slack forwarding. Leave empty to disable.
SLACK_WEBHOOK_URL=

# SMTP email forwarding. Leave ALERT_EMAIL_TO or SMTP_HOST empty to disable.
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=openwebui-alerts@example.com
SMTP_HOST=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
